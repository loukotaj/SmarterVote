# SmarterVote Local Development Environment Variables
# Copy this file to .env and fill in your API keys

# =============================================================================
# REQUIRED: At least one LLM provider
# =============================================================================

# OpenAI - Required for GPT-4o/mini
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic - Required for Claude models
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# xAI - Required for Grok models
XAI_API_KEY=xai-your-xai-key-here

# =============================================================================
# SEARCH PROVIDERS (at least one recommended for full pipeline)
# =============================================================================

# Serper.dev - Recommended (simpler, cheaper)
# Get your key at: https://serper.dev/
SERPER_API_KEY=your-serper-key-here

# Google Custom Search - Alternative
# Get your key at: https://console.cloud.google.com/
# GOOGLE_SEARCH_API_KEY=your-google-search-key-here
# GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id-here

# =============================================================================
# PIPELINE CONFIGURATION
# =============================================================================

# Cost-saving mode: Use cheaper/smaller models (gpt-4o-mini, claude-3-haiku)
# Set to "true" for local development to save API costs
SMARTERVOTE_CHEAP_MODE=true

# Provider override (optional) - force a specific provider
# Options: openai, anthropic, xai, local
# SMARTERVOTE_PROVIDER=openai

# =============================================================================
# LOCAL LLM CONFIGURATION (optional - for free local testing)
# =============================================================================

# Enable local LLM provider (requires Ollama, LM Studio, or similar running)
# LOCAL_LLM_ENABLED=true

# Local LLM server URL
# Ollama: http://localhost:11434/v1
# LM Studio: http://localhost:1234/v1
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1

# Model name (must match your local server's model)
# Ollama examples: llama3.2:3b, mistral:7b, codellama:7b
# LM Studio: use the model name shown in the UI
# LOCAL_LLM_MODEL=llama3.2:3b

# API key (usually not needed for local, but some servers require it)
# LOCAL_LLM_API_KEY=local-llm

# =============================================================================
# CACHING CONFIGURATION (optional)
# =============================================================================

# Content cache directory (defaults to data/cache)
# CONTENT_CACHE_DIR=data/cache

# Search cache TTL in hours (defaults to 168 = 7 days)
# SEARCH_CACHE_TTL_HOURS=168

# Content cache TTL in hours (defaults to 24)
# CONTENT_CACHE_TTL_HOURS=24

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Python path (auto-set by dev-start.ps1)
# PYTHONPATH=.

# =============================================================================
# PRODUCTION SETTINGS (not needed for local dev)
# =============================================================================

# Google Cloud Project (for deployed services)
# GCP_PROJECT_ID=your-project-id

# ChromaDB Cloud (production only)
# CHROMA_CLOUD_ENABLED=false

# Auth0 (web authentication, production only)
# AUTH0_SECRET=your-auth0-secret
# AUTH0_BASE_URL=http://localhost:5173
# AUTH0_ISSUER_BASE_URL=https://your-domain.auth0.com
# AUTH0_CLIENT_ID=your-client-id
# AUTH0_CLIENT_SECRET=your-client-secret
