# SmarterVote Local Development Environment Variables
# Copy this file to .env and fill in your API keys

# =============================================================================
# REQUIRED: LLM Provider
# =============================================================================

# OpenAI - Required for GPT-5.4/mini (used by the research agent)
OPENAI_API_KEY=sk-your-openai-key-here

# =============================================================================
# REQUIRED: Web Search
# =============================================================================

# Serper.dev - Required for web search during research
# Get your key at: https://serper.dev/
SERPER_API_KEY=your-serper-key-here

# =============================================================================
# OPTIONAL: Multi-LLM Review (Claude + Gemini fact-checking)
# =============================================================================

# Anthropic - Optional, enables Claude review agent
# Get your key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Google Gemini - Optional, enables Gemini review agent
# Get your key at: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-key-here

# =============================================================================
# PIPELINE CONFIGURATION
# =============================================================================

# Cost-saving mode: Use gpt-5-mini instead of gpt-5.4
# Set to "true" for local development to save API costs
SMARTERVOTE_CHEAP_MODE=true

# =============================================================================
# CACHING CONFIGURATION (optional)
# =============================================================================

# Search cache TTL in hours (defaults to 168 = 7 days)
# SEARCH_CACHE_TTL_HOURS=168

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Python path (auto-set by dev-start.ps1)
# PYTHONPATH=.

# =============================================================================
# PRODUCTION SETTINGS (not needed for local dev)
# =============================================================================

# Google Cloud Project (for deployed services)
# GCP_PROJECT_ID=your-project-id

# Auth0 (web authentication, production only)
# AUTH0_SECRET=your-auth0-secret
# AUTH0_BASE_URL=http://localhost:5173
# AUTH0_ISSUER_BASE_URL=https://your-domain.auth0.com
# AUTH0_CLIENT_ID=your-client-id
# AUTH0_CLIENT_SECRET=your-client-secret
