# Example secrets file for Terraform variables
# Copy this file to secrets.tfvars and fill in your actual values
# DO NOT commit secrets.tfvars to version control

# Google Cloud Project Configuration
project_id  = "your-gcp-project-id"
region      = "us-central1"
environment = "dev"  # dev, staging, or prod

# AI Agent API Keys (required)
openai_api_key = "sk-your-openai-api-key"
serper_api_key = "your-serper-api-key"

# Review Agent API Keys (optional — only needed for multi-LLM review)
anthropic_api_key = ""
gemini_api_key    = ""
xai_api_key       = ""

# Races API admin key — protects /analytics/* endpoints (leave empty to disable auth)
admin_api_key = ""

# Firestore: set true only on first deploy in a brand-new project (requires Owner/Editor).
# Leave false if the (default) database already exists.
create_firestore_database = false

# Pipeline Client Authentication (optional)
auth0_domain   = "your-auth0-domain"
auth0_audience = "your-auth0-audience"
allowed_origins = ["http://localhost:5173"]
